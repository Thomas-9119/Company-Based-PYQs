public class test {
  public static void main(String[] args) {
    String str = "Hello";
    String rev = "";
    for(int i=str.length()-1;i>=0;i--){
      rev += str.charAt(i);
    }
    if(rev==str){
      System.out.println("Palindrome");
    }else{
      System.out.println("not palindrome");
    }
  }
}
